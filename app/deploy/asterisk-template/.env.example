# Copie para .env e ajuste antes de rodar:
#   cp .env.example .env
#   nano .env
#   sudo bash install.sh

# Rede publica do servidor Asterisk
ASTERISK_PUBLIC_IP=
ASTERISK_DOMAIN=

# WebRTC / SIP
WEBRTC_WS_PORT=8088
WEBRTC_WSS_PORT=8089
RTP_START=10000
RTP_END=20000
DEFAULT_QUEUE_NAME=discadora
DEFAULT_QUEUE_EXTEN=700

# AMI usado pelo painel da discadora
AMI_USER=discadora
AMI_SECRET=
AMI_PERMIT=0.0.0.0/0.0.0.0

# Tronco MagnusBilling. O dialplan usa o endpoint PJSIP "magnus".
MAGNUS_SIP_HOST=
MAGNUS_SIP_PORT=5060
MAGNUS_USERNAME=
MAGNUS_AUTH_USER=
MAGNUS_PASSWORD=
MAGNUS_FROM_DOMAIN=

# TURN opcional para WebRTC
INSTALL_TURN=1
TURN_PORT=3478
TURN_REALM=
TURN_USER=discadora
TURN_PASSWORD=

# Firewall opcional via ufw
CONFIGURE_UFW=1
